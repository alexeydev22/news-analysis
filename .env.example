ENVIRONMENT=local
LOG_LEVEL=INFO
POSTGRES_DB=economic_news
POSTGRES_USER=economic_news
POSTGRES_PASSWORD=economic_news
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MLFLOW_TRACKING_URI=http://mlflow:5000
ANALYSIS_USE_STATIC_CLASSIFIER=false
ANALYSIS_TFIDF_ARTIFACT_PATH=artifacts/models/baseline/tfidf-logreg.joblib
ANALYSIS_EMBEDDING_ARTIFACT_PATH=artifacts/models/embedding/embedding-logreg.joblib
ANALYSIS_TRANSFORMER_ARTIFACT_PATH=artifacts/models/transformer/tiny-transformer-classifier.joblib
ANALYSIS_ML_DATASET_PATH=data/raw/news_impact.csv
ANALYSIS_ML_COMPARISON_PATH=artifacts/models/model_comparison.csv
ANALYSIS_ML_REPORT_OUTPUT_PATH=reports/ml/model-report.json
ANALYSIS_ML_REPORT_JOBS_DIR=reports/ml/jobs
ANALYSIS_REDIS_URL=redis://redis:6379/0
ANALYSIS_TASK_QUEUE_NAME=analysis-ml-reporting
ANALYSIS_TASK_RESULT_TTL_SECONDS=3600
RETRIEVAL_USE_STATIC_EMBEDDINGS=true
RETRIEVAL_EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DIALOG_GENERATOR_KIND=template
DIALOG_GENERATOR_NAME=template-dialog-generator
DIALOG_LLM_BASE_URL=http://localhost:8080
DIALOG_LLM_MODEL=Qwen3-0.6B-Instruct-GGUF
DIALOG_LLM_TIMEOUT_SECONDS=30.0
DIALOG_LLM_TEMPERATURE=0.2
DIALOG_LLM_MAX_TOKENS=512
NEWS_SERVICE_NEWS_DATASET_PATH=data/raw/economic_news.csv
NEWS_SERVICE_DATASET_UPLOAD_DIR=data/uploads
NEWS_SERVICE_ACTIVE_DATASET_FILE=data/uploads/active_dataset.json
NEWS_SERVICE_UPLOAD_MAX_BYTES=52428800
NEWS_SERVICE_RETRIEVAL_SERVICE_URL=http://localhost:8002
NEWS_SERVICE_RETRIEVAL_SERVICE_TIMEOUT_SECONDS=10.0
NEWS_SERVICE_DEFAULT_INDEX_LIMIT=100
NEWS_SERVICE_REDIS_URL=redis://redis:6379/0
NEWS_SERVICE_TASK_QUEUE_NAME=news-indexing
NEWS_SERVICE_TASK_RESULT_TTL_SECONDS=3600
NEWS_SERVICE_INDEX_EVENTS_CHANNEL=news.index.events
VITE_API_GATEWAY_URL=/api-gateway
VITE_NEWS_SERVICE_URL=/news-service
VITE_ANALYSIS_SERVICE_URL=/analysis-service
