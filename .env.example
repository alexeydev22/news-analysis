ANALYSIS_GEMINI_MODEL=gemini-2.5-flash
ANALYSIS_GEMINI_API_KEY=
ANALYSIS_RETRIEVAL_SERVICE_TIMEOUT_SECONDS=60.0
HF_HUB_DISABLE_XET=1
ANALYSIS_ML_TRAIN_MAX_ROWS=20000
ANALYSIS_ML_EMBEDDING_MAX_ROWS=5000
ANALYSIS_ML_TRANSFORMER_MAX_ROWS=5000
ANALYSIS_ML_COMPARISON_PATH=artifacts/models/model_comparison.csv
ANALYSIS_ML_REPORT_OUTPUT_PATH=reports/ml/model-report.json
ANALYSIS_ML_REPORT_JOBS_DIR=reports/ml/jobs
