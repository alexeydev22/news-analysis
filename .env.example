NEWS_SERVICE_RETRIEVAL_SERVICE_TIMEOUT_SECONDS=10.0
NEWS_SERVICE_DEFAULT_INDEX_LIMIT=50000
NEWS_SERVICE_INDEX_BATCH_SIZE=500
