MLFLOW_TRACKING_URI=http://mlflow:5000
ANALYSIS_USE_STATIC_CLASSIFIER=false
ANALYSIS_TFIDF_ARTIFACT_PATH=artifacts/models/baseline/tfidf-logreg.joblib
ANALYSIS_EMBEDDING_ARTIFACT_PATH=artifacts/models/embedding/embedding-logreg.joblib
ANALYSIS_TRANSFORMER_ARTIFACT_PATH=artifacts/models/transformer/tiny-transformer-classifier.joblib
ANALYSIS_ML_DATASET_PATH=data/raw/economic_news.csv
ANALYSIS_TOPIC_FORECAST_DOCUMENT_LIMIT=10000
